<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Başlık -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Smart Route"
            android:textSize="14sp"
            android:textColor="#FF7043"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textSize="12sp"
            android:textColor="#888888"/>
    </LinearLayout>

    <!-- Görev 1 -->
    <LinearLayout
        android:id="@+id/task_0_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <View
            android:id="@+id/task_0_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/task_dot"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/task_0_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""/>

        <TextView
            android:id="@+id/task_0_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:text=""/>
    </LinearLayout>

    <!-- Görev 2 -->
    <LinearLayout
        android:id="@+id/task_1_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <View
            android:id="@+id/task_1_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/task_dot"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/task_1_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""/>

        <TextView
            android:id="@+id/task_1_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:text=""/>
    </LinearLayout>

    <!-- Görev 3 -->
    <LinearLayout
        android:id="@+id/task_2_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <View
            android:id="@+id/task_2_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/task_dot"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/task_2_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="13sp"
            android:textColor="#212121"
            android:maxLines="1"
            android:ellipsize="end"
            android:text=""/>

        <TextView
            android:id="@+id/task_2_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:text=""/>
    </LinearLayout>

</LinearLayout>